    "@babel/preset-env": "7.25.4",
    "@babel/preset-react": "7.24.7",
    "@babel/preset-typescript": "7.26.0",
    "@types/react": "18.3.3",
    "@types/react-dom": "18.3.0",
    "autoprefixer": "10.4.20",
    "babel-loader": "8.4.1",
    "css-loader": "6.11.0",
    "html-webpack-plugin": "5.6.3",
    "postcss": "8.4.49",
    "postcss-loader": "4.3.0",
    "style-loader": "3.3.4",
    "typescript": "4.9.5",
    "webpack": "5.97.1",
    "webpack-cli": "4.10.0",
    "webpack-dev-server": "4.15.2",
