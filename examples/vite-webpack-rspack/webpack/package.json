{
  "name": "multi-example-webpack",
  "version": "1.0.0",
  "scripts": {
    "build": "webpack --mode production",
    "build:dev": "webpack --mode development",
    "build:start": "cd dist && PORT=8080 npx serve",
    "start": "BROWSERSLIST_IGNORE_OLD_DATA=1 webpack serve --mode development",
    "start:live": "BROWSERSLIST_IGNORE_OLD_DATA=1 webpack serve --mode development --live-reload --hot"
